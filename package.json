{
  "name": "tombolo-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Tombolo monorepo managed with pnpm workspaces and Turborepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test --continue",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "clean:deps": "pnpm -r exec rm -rf node_modules && rm -rf node_modules e2e_tests/node_modules tombolo_docs/node_modules",
    "clean:cache": "rm -rf .turbo node_modules/.cache",
    "clean:db": "rm -rf Tombolo/mysql-data Tombolo/redis-data",
    "clean:coverage": "pnpm -r exec rm -rf coverage",
    "clean:all": "pnpm clean && pnpm clean:deps && pnpm clean:cache && pnpm clean:db && rm -rf pnpm-lock.yaml && pnpm clean:coverage",
    "server:dev": "turbo dev --filter=@tombolo/server",
    "client:dev": "turbo dev --filter=@tombolo/client",
    "server:build": "turbo build --filter=@tombolo/server",
    "client:build": "turbo build --filter=@tombolo/client",
    "db:drop": "pnpm --filter=@tombolo/db db:drop",
    "db:seed": "pnpm --filter=@tombolo/db db:seed",
    "db:create": "pnpm --filter=@tombolo/db db:create",
    "db:init": "pnpm db:create && pnpm db:migrate && pnpm db:seed",
    "esm:build": "turbo build --filter=@tombolo/shared --filter=@tombolo/db --filter=@tombolo/core",
    "docker:build": "cd Tombolo && docker compose build",
    "docker:up": "cd Tombolo && docker compose up -d",
    "docker:down": "cd Tombolo && docker compose down",
    "db:migration:generate": "pnpm --filter=@tombolo/db db:migration:generate",
    "db:migrate": "pnpm --filter=@tombolo/db db:migrate",
    "helm:prepare": "cd Tombolo && ./helm/tombolo/prepare.sh",
    "helm:run": "cd Tombolo && ./helm/tombolo/run.sh",
    "helm:cleanup": "cd Tombolo && ./helm/tombolo/cleanup.sh",
    "helm:cleanup:keep-images": "cd Tombolo && ./helm/tombolo/cleanup.sh --keep-images"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "globals": "catalog:",
    "turbo": "^2.9.3",
    "typescript-eslint": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "react-error-overlay": "6.0.9",
      "glob": "^10.5.0",
      "flatted": ">=3.4.2",
      "socket.io-parser": "^4.2.6",
      "lodash": "^4.18.1",
      "serialize-javascript": "^7.0.3",
      "dompurify": "^3.3.2"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "core-js",
      "core-js-pure",
      "esbuild",
      "msgpackr-extract"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
